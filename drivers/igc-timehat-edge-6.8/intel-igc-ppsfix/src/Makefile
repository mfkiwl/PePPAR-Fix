# Intel(R) I225-LM/I225-V/I226 2.5G Ethernet Controller
# Out-of-tree build with PPS fixes for TimeHAT (kernel 6.8 port)
#
# Note: kernel 6.8 does not have igc_leds.c — LED classdev support
# was added upstream after 6.8.  Do not list igc_leds.o here.
#

ifneq ($(KERNELRELEASE),)
obj-m := igc.o
igc-y := igc_main.o igc_mac.o igc_i225.o igc_base.o igc_nvm.o igc_phy.o \
	 igc_diag.o igc_ethtool.o igc_ptp.o igc_dump.o igc_tsn.o igc_xdp.o
else
KDIR ?= /lib/modules/$(shell uname -r)/build
all:
	$(MAKE) -C $(KDIR) M=$(CURDIR) modules
clean:
	$(MAKE) -C $(KDIR) M=$(CURDIR) clean
endif
