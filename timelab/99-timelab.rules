# Lab-wide GNSS and instrument udev rules
# Only devices with unique serial numbers get stable symlinks.
# Devices without unique serials (PX1125T, Prolific console, F9T EVKs)
# must be identified by applications at runtime.
#
# Deploy to all lab hosts:
#   sudo cp 99-timelab.rules /etc/udev/rules.d/
#   sudo udevadm control --reload-rules && sudo udevadm trigger

# ── TICCs (Arduino Mega, unique serial per unit) ──
# TICC #1
SUBSYSTEM=="tty", ENV{ID_VENDOR_ID}=="2341", ENV{ID_SERIAL_SHORT}=="95037323535351803130", SYMLINK+="ticc1", MODE="0664", GROUP="dialout"
# TICC #2
SUBSYSTEM=="tty", ENV{ID_VENDOR_ID}=="2341", ENV{ID_SERIAL_SHORT}=="44236313835351B02001", SYMLINK+="ticc2", MODE="0664", GROUP="dialout"
# TICC #3
SUBSYSTEM=="tty", ENV{ID_VENDOR_ID}=="2341", ENV{ID_SERIAL_SHORT}=="44236313835351B0A091", SYMLINK+="ticc3", MODE="0664", GROUP="dialout"

# Tell ModemManager and brltty to leave Arduino devices alone.  Both
# services probe new ttyACM ports at boot/replug by sending arbitrary
# AT-style strings.  The TAPR TICC firmware interprets any byte arriving
# during its 5-second post-banner menu wait as a key press and drops
# into an interactive setup menu where it waits forever for menu
# commands instead of producing PPS timestamps.  We've hit this
# multiple times — most recently 2026-04-08 on ocxo where the TICC was
# wedged in menu mode after every reboot until we found ModemManager
# was the source of the stray bytes.
#
# These rules apply to ALL Arduino USB devices (vendor 2341), not just
# our specific TICCs.  We have no other Arduino devices in the lab
# where we'd want ModemManager or brltty to do anything, so painting
# with a broad brush is fine and protects future Arduinos automatically.
SUBSYSTEM=="tty", ENV{ID_VENDOR_ID}=="2341", ENV{ID_MM_DEVICE_IGNORE}="1"
SUBSYSTEM=="tty", ENV{ID_VENDOR_ID}=="2341", ENV{BRLTTY_DEVICE}="0"

# ── NEO-F10T on ArduSimple (FTDI FT230X, unique serial) ──
SUBSYSTEM=="tty", ENV{ID_VENDOR_ID}=="0403", ENV{ID_SERIAL_SHORT}=="D30GD1PE", SYMLINK+="f10t", MODE="0664", GROUP="dialout"

# ── PTP hardware clocks (igc driver, TimeHAT / OTC boards) ──
# Stable symlink: /dev/ptp* numbering is not stable across boots once
# the Pi's built-in gem-ptp-timer also registers a PHC.  We learned this
# on 2026-04-16 when configs aimed at /dev/ptp1 landed on gem-ptp-timer
# (n_pins=0) instead of the i226 (n_pins=2) — silent PEROUT failure.
# SYMLINK="ptp_i226" gives a name that tracks the i226 regardless of
# which /dev/ptpN the kernel happens to assign.
SUBSYSTEM=="ptp", KERNEL=="ptp[0-9]*", DRIVERS=="igc", SYMLINK+="ptp_i226", MODE="0664", GROUP="dialout"

# ── Host ocxo: stable network interface names (MAC-keyed) ──
# Three NIC families share this host and the kernel/systemd default
# names (enp1s0f0np0, enp2s0, eno1) don't make any of them obvious.
# Identical-board swap is considered unlikely so MACs are pinned.
# Other hosts are unaffected — the MAC match makes these rules ocxo-only.
#
# E810-XXVDA4T (Intel ice driver) — the OCXO-disciplined PHC, /dev/ptp1
SUBSYSTEM=="net", ACTION=="add", DRIVERS=="ice", ATTR{address}=="50:7c:6f:53:d5:38", NAME="e810p0"
SUBSYSTEM=="net", ACTION=="add", DRIVERS=="ice", ATTR{address}=="50:7c:6f:53:d5:39", NAME="e810p1"
SUBSYSTEM=="net", ACTION=="add", DRIVERS=="ice", ATTR{address}=="50:7c:6f:53:d5:3a", NAME="e810p2"
SUBSYSTEM=="net", ACTION=="add", DRIVERS=="ice", ATTR{address}=="50:7c:6f:53:d5:3b", NAME="e810p3"
#
# TimeHAT v6 i226 add-in (Intel igc driver) — second PHC for cross-comparison
SUBSYSTEM=="net", ACTION=="add", DRIVERS=="igc", ATTR{address}=="f0:b2:b9:31:a7:86", NAME="i226"
#
# Onboard motherboard NIC (Intel e1000e) — PTP slave-only, no PHC servo use
SUBSYSTEM=="net", ACTION=="add", DRIVERS=="e1000e", ATTR{address}=="a0:8c:fd:da:a9:b1", NAME="mbeth"

