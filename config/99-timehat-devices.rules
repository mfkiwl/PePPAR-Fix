# Stable symlinks for GNSS receiver and TICC on TimeHat (Raspberry Pi 5).
#
# Install: sudo cp 99-timehat-devices.rules /etc/udev/rules.d/
#          sudo udevadm control --reload-rules && sudo udevadm trigger
#
# To discover IDs after plugging in a new device:
#   udevadm info /dev/ttyACMx | grep -E 'ID_PATH|ID_VENDOR_ID|ID_SERIAL_SHORT'
#
# Pattern copied from testAnt rig (99-ublox-gnss.rules) — see shared_files.toml.

# u-blox ZED-F9T-3RD (EVK-F9T-20-00) — matched by USB physical path
# because all F9T EVKs share VID:PID 1546:01a9 and identical serial descriptors.
# To re-identify: watch `ls /dev/serial/by-path/` while unplugging.
# Updated 2026-03-16: moved from xhci-hcd.0 port 2 to xhci-hcd.1 port 1
SUBSYSTEM=="tty", \
  ENV{ID_VENDOR_ID}=="1546", \
  ENV{ID_MODEL_ID}=="01a9", \
  ENV{ID_PATH}=="platform-xhci-hcd.1-usb-0:1:1.0", \
  SYMLINK+="gnss-top", \
  MODE="0664", \
  GROUP="dialout"

# TAPR TICC time interval counter (Arduino Mega, matched by serial number)
# chA = TimeHAT PHC PPS OUT (SDP0, SMA1 J4, disciplined)
# chB = F9T-3RD PPS (raw GPS reference)
# ref = 10 MHz from SV1AFN distribution amp (fed by Geppetto GPSDO)
# Note: serial number is unit-specific. Run:
#   udevadm info /dev/ttyACMx | grep ID_SERIAL_SHORT
# to find the right value for your TICC.
SUBSYSTEM=="tty", \
  ENV{ID_VENDOR_ID}=="2341", \
  ENV{ID_SERIAL_SHORT}=="95037323535351803130", \
  SYMLINK+="ticc", \
  MODE="0664", \
  GROUP="dialout"

# TimeHAT i226 PTP device — allow dialout group access without sudo
# The i226 MAC address starts with 54:49:4d:45 ("TIME").
# Match by the igc driver creating ptp devices.
SUBSYSTEM=="ptp", \
  KERNEL=="ptp[0-9]*", \
  DRIVERS=="igc", \
  MODE="0664", \
  GROUP="dialout"
