#!/usr/bin/env bash
# peppar-mon — status display for PePPAR-Fix
#
# Thin launcher: discovers the Python venv, sets PYTHONPATH so the
# top-level `peppar_mon` package is importable, and execs the app.
#
# Usage:
#   peppar-mon PATH/engine.log           # TUI in the current terminal
#   peppar-mon --web 8000 PATH/eng.log   # textual serve to browser on :8000
#
# The log file argument is mandatory — peppar-mon's display is driven
# entirely by the engine's log, so running without one has nothing to
# show.  The monitor reads the log file but does not import engine
# internals; see peppar_mon/__init__.py for the boundary contract.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

PYTHON_BIN="python3"
if [[ -x "$REPO_ROOT/venv/bin/python" ]]; then
    PYTHON_BIN="$REPO_ROOT/venv/bin/python"
elif [[ -x "$HOME/pygpsclient/bin/python" ]]; then
    PYTHON_BIN="$HOME/pygpsclient/bin/python"
fi

# Repo root on PYTHONPATH so `import peppar_mon` works.  We intentionally
# do NOT add scripts/ — peppar-mon must not be able to import engine
# modules by accident.  The boundary test enforces this at check time;
# the launcher enforces it at run time.
export PYTHONPATH="$REPO_ROOT${PYTHONPATH:+:$PYTHONPATH}"

# --web → textual-serve web terminal; everything else → direct TUI run.
if [[ "${1:-}" == "--web" ]]; then
    shift
    PORT="${1:-8000}"
    [[ "${1:-}" =~ ^[0-9]+$ ]] && shift || true
    if [[ $# -lt 1 ]]; then
        echo "usage: peppar-mon --web PORT LOG_FILE" >&2
        exit 2
    fi
    LOG_FILE="$1"
    shift
    # Textual 8.x removed the in-tree `textual serve` subcommand and
    # split it into the standalone `textual-serve` package, which
    # takes a shell *command* rather than an APP:CLASS import target.
    # peppar_mon._serve wraps that cleanly so the web path runs the
    # same `python -m peppar_mon LOG_FILE` invocation as the direct
    # TUI — the two codepaths behave identically.
    exec "$PYTHON_BIN" -m peppar_mon._serve "$PORT" "$LOG_FILE"
else
    exec "$PYTHON_BIN" -m peppar_mon "$@"
fi
