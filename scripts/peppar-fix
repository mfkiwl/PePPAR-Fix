#!/usr/bin/env bash
# peppar-fix — GNSS-disciplined PTP clock appliance
#
# Composes three tools with retry logic and exponential backoff:
#   1. peppar-rx-config   — verify/configure receiver
#   2. peppar-find-position — bootstrap antenna position (if needed)
#   3. peppar-fix-engine  — maintain software clock, optionally discipline PHC
#
# Exit codes from peppar-fix-engine drive retry behavior:
#   0 = clean shutdown
#   1 = error (fatal)
#   2 = position moved (re-bootstrap position, then restart servo)
#   3 = no PPS (retry with backoff)
#   4 = divergence (fatal)
#   5 = PHC diverged (re-bootstrap PHC, then restart servo)
#
# Configuration via environment variables or command-line overrides:
#   PEPPAR_SERIAL       Serial port (e.g. /dev/gnss-top)
#   PEPPAR_BAUD         Baud rate (default: 9600)
#   PEPPAR_UBX_PORT     u-blox logical output port: UART, UART2, USB, or SPI (default: USB)
#   PEPPAR_PORT_TYPE    Deprecated alias for PEPPAR_UBX_PORT
#   PEPPAR_RECEIVER     Receiver profile (default: f9t)
#   PEPPAR_PTP_PROFILE  PTP profile (optional)
#   PEPPAR_HOST_CONFIG  Explicit host config TOML (optional)
#   PEPPAR_PTP_DEV      PTP device (no default — must be set explicitly or via host config)
#   PEPPAR_NTRIP_CONF   NTRIP config file
#   PEPPAR_EPH_MOUNT    Ephemeris mountpoint
#   PEPPAR_SSR_MOUNT    SSR mountpoint (optional)
#   PEPPAR_KNOWN_POS    Known position as lat,lon,alt (optional)
#   PEPPAR_POSITION_FILE Position file (default: data/position.json)
#   PEPPAR_SYSTEMS      GNSS systems (default: gps,gal,bds)
#   PEPPAR_DURATION     Servo duration in seconds (optional)
#   PEPPAR_LOG          CSV log file (optional)
#
# Usage:
#   peppar-fix                              # use env vars
#   peppar-fix --serial /dev/gnss-top ...   # override on CLI

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
PYTHON_BIN="python3"
if [[ -x "$REPO_ROOT/venv/bin/python" ]]; then
    PYTHON_BIN="$REPO_ROOT/venv/bin/python"
elif [[ -x "$HOME/pygpsclient/bin/python" ]]; then
    PYTHON_BIN="$HOME/pygpsclient/bin/python"
fi
export PYTHONPATH="$REPO_ROOT/scripts${PYTHONPATH:+:$PYTHONPATH}"

# ── Defaults from environment ───────────────────────────────────────────── #

SERIAL="${PEPPAR_SERIAL:-}"
BAUD="${PEPPAR_BAUD:-}"
UBX_PORT="${PEPPAR_UBX_PORT:-${PEPPAR_PORT_TYPE:-}}"
RECEIVER="${PEPPAR_RECEIVER:-}"
PTP_PROFILE="${PEPPAR_PTP_PROFILE:-}"
PTP_DEV="${PEPPAR_PTP_DEV:-}"
NTRIP_CONF="${PEPPAR_NTRIP_CONF:-}"
EPH_MOUNT="${PEPPAR_EPH_MOUNT:-}"
SSR_MOUNT="${PEPPAR_SSR_MOUNT:-}"
KNOWN_POS="${PEPPAR_KNOWN_POS:-}"
POSITION_FILE="${PEPPAR_POSITION_FILE:-}"
SYSTEMS="${PEPPAR_SYSTEMS:-}"
DURATION="${PEPPAR_DURATION:-}"
LOG_FILE="${PEPPAR_LOG:-}"
PHASE_STEP_BIAS_NS="${PEPPAR_PHASE_STEP_BIAS_NS:-}"
PMC_UDS="${PEPPAR_PMC_UDS:-}"
PMC_DOMAIN="${PEPPAR_PMC_DOMAIN:-0}"
ENGINE_EXTRA_ARGS=()
FREERUN=""

is_kernel_gnss_device() {
    local path="${1:-}"
    local base
    base="$(basename "$path")"
    [[ "$base" =~ ^gnss[0-9]+$ ]]
}

# ── Parse CLI overrides ─────────────────────────────────────────────────── #

usage() {
    cat <<'EOF'
Usage: peppar-fix [options]

GNSS-disciplined PTP clock appliance.

Options:
  --serial PORT        Serial port (e.g. /dev/gnss-top)
  --baud RATE          Baud rate (default: 9600)
  --ubx-port TYPE      u-blox logical output port: UART, UART2, USB, or SPI (default: USB)
  --port-type TYPE     Deprecated alias for --ubx-port
  --receiver NAME      Receiver profile (default: f9t)
  --ptp-profile NAME   PTP profile (e.g. i226, e810)
  --host-config FILE   Explicit host config TOML
  --ptp-dev DEV        PTP device (default: /dev/ptp0)
  --ntrip-conf FILE    NTRIP config file
  --eph-mount MOUNT    Broadcast ephemeris mountpoint
  --ssr-mount MOUNT    SSR corrections mountpoint
  --known-pos LAT,LON,ALT  Known position (skips position bootstrap)
  --position-file FILE Position file (default: data/position.json)
  --systems SYS        GNSS systems (default: gps,gal,bds)
  --duration SECS      Servo duration in seconds
  --log FILE           CSV log file
  --phase-step-bias-ns NS  Per-host PHC phase-step bias compensation in ns
  --pmc UDS_PATH       ptp4l UDS path for clockClass supervision
  --pmc-domain NUM     PTP domain (must match ptp4l, default: 0)
  --freerun            Run without steering PHC (characterization mode)
  --engine-arg ARG     Extra argument passed through to peppar-fix-engine
  -h, --help           Show this help

Environment variables (PEPPAR_*) provide defaults. CLI overrides them.
EOF
    exit 0
}

HOST_CONFIG="${PEPPAR_HOST_CONFIG:-}"

while [[ $# -gt 0 ]]; do
    case "$1" in
        --serial)       SERIAL="$2"; shift 2 ;;
        --baud)         BAUD="$2"; shift 2 ;;
        --ubx-port|--port-type) UBX_PORT="$2"; shift 2 ;;
        --receiver)     RECEIVER="$2"; shift 2 ;;
        --ptp-profile)  PTP_PROFILE="$2"; shift 2 ;;
        --host-config)  HOST_CONFIG="$2"; shift 2 ;;
        --ptp-dev)      PTP_DEV="$2"; shift 2 ;;
        --ntrip-conf)   NTRIP_CONF="$2"; shift 2 ;;
        --eph-mount)    EPH_MOUNT="$2"; shift 2 ;;
        --ssr-mount)    SSR_MOUNT="$2"; shift 2 ;;
        --known-pos)    KNOWN_POS="$2"; shift 2 ;;
        --position-file) POSITION_FILE="$2"; shift 2 ;;
        --systems)      SYSTEMS="$2"; shift 2 ;;
        --duration)     DURATION="$2"; shift 2 ;;
        --log)          LOG_FILE="$2"; shift 2 ;;
        --phase-step-bias-ns) PHASE_STEP_BIAS_NS="$2"; shift 2 ;;
        --pmc)          PMC_UDS="$2"; shift 2 ;;
        --pmc-domain)   PMC_DOMAIN="$2"; shift 2 ;;
        --freerun)       FREERUN=1; shift ;;
        --engine-arg)   ENGINE_EXTRA_ARGS+=("$2"); shift 2 ;;
        -h|--help)      usage ;;
        *)              echo "Unknown option: $1" >&2; exit 1 ;;
    esac
done

HOSTCFG_PATH=""
if hostcfg_eval="$("$PYTHON_BIN" "$SCRIPT_DIR/peppar_host_config.py" --repo-root "$REPO_ROOT" --explicit "$HOST_CONFIG")"; then
    eval "$hostcfg_eval"
fi

SERIAL="${SERIAL:-${HOSTCFG_SERIAL:-}}"
BAUD="${BAUD:-${HOSTCFG_BAUD:-9600}}"
if is_kernel_gnss_device "$SERIAL"; then
    BAUD=""
fi
UBX_PORT="${UBX_PORT:-${HOSTCFG_UBX_PORT:-${HOSTCFG_PORT_TYPE:-USB}}}"
RECEIVER="${RECEIVER:-${HOSTCFG_RECEIVER:-f9t}}"
PTP_PROFILE="${PTP_PROFILE:-${HOSTCFG_PTP_PROFILE:-}}"
PTP_DEV="${PTP_DEV:-${HOSTCFG_PTP_DEV:-}}"
NTRIP_CONF="${NTRIP_CONF:-${HOSTCFG_NTRIP_CONF:-}}"
EPH_MOUNT="${EPH_MOUNT:-${HOSTCFG_EPH_MOUNT:-}}"
SSR_MOUNT="${SSR_MOUNT:-${HOSTCFG_SSR_MOUNT:-}}"
KNOWN_POS="${KNOWN_POS:-${HOSTCFG_KNOWN_POS:-}}"
POSITION_FILE="${POSITION_FILE:-${HOSTCFG_POSITION_FILE:-data/position.json}}"
SYSTEMS="${SYSTEMS:-${HOSTCFG_SYSTEMS:-gps,gal,bds}}"
DURATION="${DURATION:-${HOSTCFG_DURATION:-}}"
LOG_FILE="${LOG_FILE:-${HOSTCFG_LOG:-}}"
PHASE_STEP_BIAS_NS="${PHASE_STEP_BIAS_NS:-${HOSTCFG_PHASE_STEP_BIAS_NS:-}}"
PMC_UDS="${PMC_UDS:-${HOSTCFG_PMC_UDS:-}}"
PMC_DOMAIN="${PMC_DOMAIN:-${HOSTCFG_PMC_DOMAIN:-0}}"

# Extract --ticc-port from engine args so bootstrap can verify PEROUT phase
TICC_PORT=""
for ((i=0; i<${#ENGINE_EXTRA_ARGS[@]}; i++)); do
    if [[ "${ENGINE_EXTRA_ARGS[i]}" == "--ticc-port" ]] && [[ $((i+1)) -lt ${#ENGINE_EXTRA_ARGS[@]} ]]; then
        TICC_PORT="${ENGINE_EXTRA_ARGS[i+1]}"
        break
    fi
done

# ── Validate required config ────────────────────────────────────────────── #

if [[ -z "$SERIAL" ]]; then
    echo "ERROR: --serial or PEPPAR_SERIAL required" >&2
    exit 1
fi

if [[ -z "$EPH_MOUNT" && -z "$NTRIP_CONF" ]]; then
    echo "ERROR: --eph-mount or --ntrip-conf required" >&2
    exit 1
fi

# ── Helper: build common NTRIP args ─────────────────────────────────────── #

ntrip_args() {
    local args=()
    if [[ -n "$NTRIP_CONF" ]]; then
        args+=(--ntrip-conf "$NTRIP_CONF")
    fi
    if [[ -n "$EPH_MOUNT" ]]; then
        args+=(--eph-mount "$EPH_MOUNT")
    fi
    if [[ -n "$SSR_MOUNT" ]]; then
        args+=(--ssr-mount "$SSR_MOUNT")
    fi
    echo "${args[@]}"
}

# ── Run engine ─────────────────────────────────────────────────────────── #
# Receiver config, position bootstrap, DO bootstrap, PPS retry, and PHC
# re-bootstrap are all handled internally by the engine.  The wrapper's
# remaining job: venv discovery, config resolution, one-time DO
# characterization, and the engine invocation.

# ── Step 2c: One-time DO characterization ──────────────────────────────── #
# Run a 30-minute --freerun once per host to capture the DO's noise
# floor and the PSDs of every error source.  Stored in
# data/do_characterization.json.  Skipped if the file already exists.
# The engine reads this file at startup and prints recommended loop
# bandwidths for each candidate servo input.

DO_CHAR_FILE="${PEPPAR_DO_CHAR_FILE:-data/do_characterization.json}"
DO_CHAR_DURATION="${PEPPAR_DO_CHAR_DURATION:-1800}"

if [[ -n "$PTP_DEV" ]] && [[ -e "$PTP_DEV" ]] && [[ -z "$FREERUN" ]] \
        && [[ ! -f "$DO_CHAR_FILE" ]] && [[ -n "$KNOWN_POS" ]]; then
    echo "=== peppar-fix: Step 2c — One-time DO characterization (${DO_CHAR_DURATION}s freerun) ==="
    echo "  Building $DO_CHAR_FILE"
    char_csv="data/freerun_char.csv"
    char_args=(
        --serial "$SERIAL"
        --port-type "$UBX_PORT"
        --known-pos "$KNOWN_POS"
        --servo "$PTP_DEV"
        --freerun
        --duration "$DO_CHAR_DURATION"
        --servo-log "$char_csv"
        --watchdog-threshold 1000000000
        --freerun-max-error-ns 100000000
        --track-outlier-ns 100000000
        --track-restep-ns 100000000
    )
    if [[ -n "$BAUD" ]]; then
        char_args+=(--baud "$BAUD")
    fi
    if [[ -n "$PTP_PROFILE" ]]; then
        char_args+=(--ptp-profile "$PTP_PROFILE")
    fi
    # shellcheck disable=SC2046
    char_args+=($(ntrip_args))
    if "$PYTHON_BIN" "$SCRIPT_DIR/peppar_fix_engine.py" "${char_args[@]}"; then
        do_label="${PEPPAR_DO_LABEL:-${PTP_PROFILE:-unknown}}"
        "$PYTHON_BIN" "$SCRIPT_DIR/../tools/build_do_characterization.py" \
            --input "$char_csv" \
            --output "$DO_CHAR_FILE" \
            --do-label "$do_label" \
            --phc "$PTP_DEV" || \
            echo "  WARNING: characterization build failed; continuing without file" >&2
    else
        echo "  WARNING: freerun characterization failed (rc=$?); continuing without file" >&2
    fi
fi

echo "=== peppar-fix: Step 3 — Unified engine ==="

build_servo_args() {
    local args=(
        --serial "$SERIAL"
        --receiver "$RECEIVER"
        --systems "$SYSTEMS"
    )
    if [[ -n "$BAUD" ]]; then
        args+=(--baud "$BAUD")
    fi
    if [[ -n "$PTP_PROFILE" ]]; then
        args+=(--ptp-profile "$PTP_PROFILE")
    fi
    if [[ -n "$PTP_DEV" ]]; then
        args+=(--servo "$PTP_DEV")
    fi
    if [[ -n "$KNOWN_POS" ]]; then
        args+=(--known-pos "$KNOWN_POS")
    elif [[ -f "$POSITION_FILE" ]]; then
        args+=(--position-file "$POSITION_FILE")
    fi
    # shellcheck disable=SC2046
    args+=($(ntrip_args))
    if [[ -n "$DURATION" ]]; then
        args+=(--duration "$DURATION")
    fi
    if [[ -n "$LOG_FILE" ]]; then
        args+=(--servo-log "$LOG_FILE")
    fi
    if [[ -n "$PHASE_STEP_BIAS_NS" ]]; then
        args+=(--phase-step-bias-ns "$PHASE_STEP_BIAS_NS")
    fi
    if [[ -n "$PMC_UDS" ]]; then
        args+=(--pmc "$PMC_UDS" --pmc-domain "$PMC_DOMAIN")
    fi
    if [[ -n "$FREERUN" ]]; then
        args+=(--freerun)
    fi
    # External DO support
    if [[ -n "${HOSTCFG_DO_LABEL:-}" ]]; then
        args+=(--do-label "$HOSTCFG_DO_LABEL")
    fi
    if [[ -n "${HOSTCFG_DO_TYPE:-}" ]]; then
        args+=(--do-type "$HOSTCFG_DO_TYPE")
    fi
    if [[ -n "${HOSTCFG_DAC_BUS:-}" ]]; then
        args+=(--dac-bus "$HOSTCFG_DAC_BUS")
        [[ -n "${HOSTCFG_DAC_ADDR:-}" ]] && args+=(--dac-addr "$HOSTCFG_DAC_ADDR")
        [[ -n "${HOSTCFG_DAC_BITS:-}" ]] && args+=(--dac-bits "$HOSTCFG_DAC_BITS")
        [[ -n "${HOSTCFG_DAC_CENTER_CODE:-}" ]] && args+=(--dac-center-code "$HOSTCFG_DAC_CENTER_CODE")
        [[ -n "${HOSTCFG_DAC_PPB_PER_CODE:-}" ]] && args+=(--dac-ppb-per-code "$HOSTCFG_DAC_PPB_PER_CODE")
        [[ -n "${HOSTCFG_DAC_MAX_PPB:-}" ]] && args+=(--dac-max-ppb "$HOSTCFG_DAC_MAX_PPB")
        [[ -n "${HOSTCFG_DAC_TYPE:-}" ]] && args+=(--dac-type "$HOSTCFG_DAC_TYPE")
    fi
    if [[ -n "${HOSTCFG_TADD_GPIO:-}" ]]; then
        args+=(--tadd-gpio "$HOSTCFG_TADD_GPIO")
        [[ -n "${HOSTCFG_TADD_HOLD_S:-}" ]] && args+=(--tadd-hold-s "$HOSTCFG_TADD_HOLD_S")
    fi
    if [[ ${#ENGINE_EXTRA_ARGS[@]} -gt 0 ]]; then
        args+=("${ENGINE_EXTRA_ARGS[@]}")
    fi
    echo "${args[@]}"
}

# All retry logic (PPS retry, PHC re-bootstrap, position re-bootstrap) is
# now handled internally by the engine.  The wrapper just invokes it once.
# Systemd Restart=on-failure handles crash recovery.
set +e
# shellcheck disable=SC2046
"$PYTHON_BIN" "$SCRIPT_DIR/peppar_fix_engine.py" $(build_servo_args)
rc=$?
set -e

case $rc in
    0)
        echo "peppar-fix: clean shutdown"
        # If this was an explicit --freerun, build the DO
        # characterization file from the resulting servo log.
        if [[ -n "$FREERUN" ]] && [[ -n "$LOG_FILE" ]] && [[ -f "$LOG_FILE" ]]; then
            do_label="${PEPPAR_DO_LABEL:-${PTP_PROFILE:-unknown}}"
            echo "=== Building DO characterization from $LOG_FILE ==="
            "$PYTHON_BIN" "$SCRIPT_DIR/../tools/build_do_characterization.py" \
                --input "$LOG_FILE" \
                --output "$DO_CHAR_FILE" \
                --do-label "$do_label" \
                --phc "$PTP_DEV" || true
        fi
        exit 0
        ;;
    5)
        if [[ -n "$FREERUN" ]]; then
            echo "peppar-fix: freerun auto-stop (PPS error exceeded threshold)"
            exit 0
        fi
        echo "peppar-fix: PHC diverged — engine re-bootstrap exhausted" >&2
        exit 5
        ;;
    *)
        echo "peppar-fix: fatal error (exit code $rc)" >&2
        exit "$rc"
        ;;
esac
