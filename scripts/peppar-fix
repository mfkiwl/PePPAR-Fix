#!/usr/bin/env bash
# peppar-fix — GNSS-disciplined PTP clock appliance
#
# Thin launcher: discovers the Python venv, sets PYTHONPATH, and execs
# peppar_fix_engine.py.  All intelligence (receiver config, position
# bootstrap, DO bootstrap, PPS retry, PHC re-bootstrap, host config
# resolution) lives in the engine.
#
# The wrapper still owns two bash-specific responsibilities:
#   - Venv/Python discovery (no good cross-platform way in Python)
#   - One-time DO characterization (runs engine in --freerun mode,
#     then post-processes with build_do_characterization.py)
#
# Configuration: the engine auto-discovers config/<hostname>.toml or
# accepts --host-config.  CLI args and PEPPAR_* env vars override.
#
# Usage:
#   peppar-fix                              # auto-discover host config
#   peppar-fix --serial /dev/gnss-top ...   # override on CLI
#   peppar-fix --host-config config/clkpoc3.toml  # explicit host config

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
PYTHON_BIN="python3"
if [[ -x "$REPO_ROOT/venv/bin/python" ]]; then
    PYTHON_BIN="$REPO_ROOT/venv/bin/python"
elif [[ -x "$HOME/pygpsclient/bin/python" ]]; then
    PYTHON_BIN="$HOME/pygpsclient/bin/python"
fi
export PYTHONPATH="$REPO_ROOT/scripts${PYTHONPATH:+:$PYTHONPATH}"

# ── One-time DO characterization ───────────────────────────────────────── #
# Run a 30-minute --freerun once per host to capture the DO's noise floor.
# Skipped if data/do_characterization.json already exists.  This stays in
# the wrapper because it orchestrates two engine invocations (freerun +
# build_do_characterization.py) and the engine shouldn't invoke itself.
#
# TODO: Move to a separate tool (peppar-characterize-do) or systemd oneshot.

DO_CHAR_FILE="${PEPPAR_DO_CHAR_FILE:-data/do_characterization.json}"

if [[ ! -f "$DO_CHAR_FILE" ]]; then
    # Resolve host config to check for PTP_DEV and KNOWN_POS
    _hc_eval=""
    _hc_explicit=""
    for arg in "$@"; do
        if [[ "$_hc_flag" == "1" ]]; then
            _hc_explicit="$arg"
            _hc_flag=""
            break
        fi
        [[ "$arg" == "--host-config" ]] && _hc_flag=1
    done
    if _hc_eval="$("$PYTHON_BIN" "$SCRIPT_DIR/peppar_host_config.py" \
            --repo-root "$REPO_ROOT" --explicit "${_hc_explicit:-${PEPPAR_HOST_CONFIG:-}}" 2>/dev/null)"; then
        eval "$_hc_eval"
    fi
    _ptp_dev="${PEPPAR_PTP_DEV:-${HOSTCFG_PTP_DEV:-}}"
    _known_pos="${PEPPAR_KNOWN_POS:-${HOSTCFG_KNOWN_POS:-}}"
    # Check CLI args for --servo or --known-pos overrides
    _prev=""
    for arg in "$@"; do
        [[ "$_prev" == "--servo" ]] && _ptp_dev="$arg"
        [[ "$_prev" == "--known-pos" ]] && _known_pos="$arg"
        _prev="$arg"
    done

    if [[ -n "$_ptp_dev" ]] && [[ -e "$_ptp_dev" ]] && [[ -n "$_known_pos" ]]; then
        DO_CHAR_DURATION="${PEPPAR_DO_CHAR_DURATION:-1800}"
        echo "=== peppar-fix: One-time DO characterization (${DO_CHAR_DURATION}s freerun) ==="
        char_csv="data/freerun_char.csv"
        mkdir -p data
        if "$PYTHON_BIN" "$SCRIPT_DIR/peppar_fix_engine.py" "$@" \
                --freerun --duration "$DO_CHAR_DURATION" \
                --servo-log "$char_csv" \
                --watchdog-threshold 1000000000 \
                --freerun-max-error-ns 100000000 \
                --track-outlier-ns 100000000 \
                --track-restep-ns 100000000; then
            do_label="${PEPPAR_DO_LABEL:-${HOSTCFG_DO_LABEL:-unknown}}"
            "$PYTHON_BIN" "$SCRIPT_DIR/../tools/build_do_characterization.py" \
                --input "$char_csv" \
                --output "$DO_CHAR_FILE" \
                --do-label "$do_label" \
                --phc "$_ptp_dev" || \
                echo "  WARNING: characterization build failed; continuing without" >&2
        else
            echo "  WARNING: freerun characterization failed; continuing without" >&2
        fi
    fi
fi

# ── Run engine ─────────────────────────────────────────────────────────── #
exec "$PYTHON_BIN" "$SCRIPT_DIR/peppar_fix_engine.py" "$@"
