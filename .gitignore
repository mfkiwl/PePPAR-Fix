# Observation data and correction products (large, downloadable)
data/

# Host-local state (receiver identity, position, DO characterization).
# Runtime JSON is host-specific; README.md files are checked in so
# lab hosts get directory descriptions on pull.
state/**/*.json
state/**/*.tmp

# Credentials — any ntrip*.conf variant (ntrip-cnes.conf,
# ntrip-whu.conf, …) is gitignored; the *.example templates are
# re-included explicitly.
ntrip*.conf
!ntrip*.conf.example
*.secrets

# Antenna positions — never commit surveyed coords.  Authoritative
# positions live in the (private) timelab repo at timelab/antPos.json;
# runtime positions live in state/receivers/<uid>.json (covered
# above).  This belt-and-suspenders entry catches antPos.json if it
# ever ends up inside this tree by accident.
antPos.json
*-pos.json

# Python
__pycache__/
*.pyc
.venv/

# Binary dumps
*.rtcm
*.bin
